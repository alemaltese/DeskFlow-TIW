<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} — Helpdesk</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="nav-brand">Helpdesk</a>
      <div class="nav-links">
        {{#if currentUser}}
          {{#if isAdmin}}
            <a href="/admin/dashboard">Dashboard</a>
            <a href="/admin/tickets">Ticket</a>
            <a href="/admin/utenti">Utenti</a>
            <a href="/admin/stats">Statistiche</a>
            <a href="/admin/profilo">{{currentUser.name}}</a>
          {{else}}
            {{#if isOperatore}}
              <a href="/operatore/dashboard">Dashboard</a>
              <a href="/operatore/tickets">Ticket</a>
              <a href="/operatore/profilo">{{currentUser.name}}</a>
            {{else}}
              <a href="/tickets">I miei ticket</a>
              <a href="/profilo">{{currentUser.name}}</a>
            {{/if}}
          {{/if}}
          <a href="/logout">Esci</a>
        {{else}}
          <a href="/login">Accedi</a>
          <a href="/register">Registrati</a>
        {{/if}}
      </div>
    </div>
  </nav>
  <main class="container">
    {{#if flash}}
      <div class="flash flash-{{flash.type}}">{{flash.message}}</div>
    {{/if}}
    {{{body}}}
  </main>
  <script>
  function togglePw(btn) {
    const input = btn.closest('.pw-wrap').querySelector('input');
    const isHidden = input.type === 'password';
    input.type = isHidden ? 'text' : 'password';
    btn.setAttribute('aria-label', isHidden ? 'Nascondi password' : 'Mostra password');
    btn.querySelector('svg').innerHTML = isHidden
      ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>'
      : '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
  }
  </script>
</body>
</html>
