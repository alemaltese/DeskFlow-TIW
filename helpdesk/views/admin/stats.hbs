<div style="margin-bottom:1.5rem;">
  <h1>Dashboard Analytics</h1>
</div>

{{!-- KPI --}}
<div class="kpi-grid" style="margin-bottom:2rem;">
  <div class="kpi-card blue">
    <div class="kpi-number">{{kpi.totalTickets}}</div>
    <div class="kpi-label">Ticket aperti nel periodo</div>
  </div>
  <div class="kpi-card amber">
    <div class="kpi-number">{{#if kpi.avgFirstResponse}}{{kpi.avgFirstResponse}}h{{else}}—{{/if}}</div>
    <div class="kpi-label">Tempo medio prima risposta</div>
  </div>
  <div class="kpi-card green">
    <div class="kpi-number">{{#if kpi.avgResolution}}{{kpi.avgResolution}}h{{else}}—{{/if}}</div>
    <div class="kpi-label">Tempo medio risoluzione</div>
  </div>
  <div class="kpi-card purple">
    <div class="kpi-number">
      {{#if kpi.avgRating}}
        {{kpi.avgRating}}
        <span style="font-size:1rem; color:#f59e0b;">
          {{#each kpi.avgRatingStars}}{{#if this}}★{{else}}☆{{/if}}{{/each}}
        </span>
      {{else}}—{{/if}}
    </div>
    <div class="kpi-label">Rating medio</div>
  </div>
</div>

<div class="two-col-layout">
  <div class="col-main">

    {{!-- Workload operatori --}}
    <div class="card" style="margin-bottom:1.5rem;">
      <div class="card-header">
        <h3 class="card-title">Workload operatori</h3>
        <span style="font-size:12px;color:#64748b;">Ticket attivi vs risolti per operatore</span>
      </div>
      {{#each workload}}
      <div style="margin-bottom:18px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
          <strong style="font-size:14px;color:#1e293b;">{{this.name}}</strong>
          <span style="font-size:12px;color:#64748b;">
            {{this.attivi}} attivi · {{this.risolti}} risolti · {{this.chiusi}} chiusi
          </span>
        </div>
        <div style="margin-bottom:4px;">
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:11px;color:#64748b;width:52px;">Attivi</span>
            <div class="bar-container" style="flex:1;">
              <div class="bar" style="width:{{this.attiviPerc}}%;background:#f59e0b;">{{this.attivi}}</div>
            </div>
          </div>
        </div>
        <div>
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:11px;color:#64748b;width:52px;">Risolti</span>
            <div class="bar-container" style="flex:1;">
              <div class="bar" style="width:{{this.risoltiPerc}}%;background:#22c55e;">{{this.risolti}}</div>
            </div>
          </div>
        </div>
      </div>
      {{/each}}
      {{#unless workload}}
      <p style="color:#94a3b8;font-size:13px;">Nessun operatore presente.</p>
      {{/unless}}
    </div>

    {{!-- Performance operatori --}}
    <div class="card" style="margin-bottom:1.5rem;">
      <h2>Performance operatori</h2>
      {{#if operatorPerf.length}}
      <table style="margin-top:0.75rem;">
        <thead>
          <tr>
            <th>Nome</th>
            <th>Assegnati</th>
            <th>Risolti</th>
            <th>Rating medio</th>
          </tr>
        </thead>
        <tbody>
          {{#each operatorPerf}}
          <tr>
            <td>{{this.name}}</td>
            <td>{{this.ticket_assegnati}}</td>
            <td>{{this.ticket_risolti}}</td>
            <td>
              {{#if this.starsArr}}
                <span style="color:#f59e0b; letter-spacing:1px;">
                  {{#each this.starsArr}}{{#if this}}★{{else}}☆{{/if}}{{/each}}
                </span>
                <span style="font-size:0.8rem; color:#64748b; margin-left:4px;">{{../rating_medio}}</span>
              {{else}}
                <span class="text-muted">—</span>
              {{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{else}}
      <p class="text-muted" style="margin-top:0.75rem;">Nessun operatore.</p>
      {{/if}}
    </div>

    {{!-- Tasso di risoluzione per categoria --}}
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Tasso di risoluzione per categoria</h3>
        <span style="font-size:12px;color:#64748b;">% ticket risolti o chiusi sul totale</span>
      </div>
      {{#each tassoCategoria}}
      <div style="margin-bottom:16px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;">
          <span style="font-size:13px;font-weight:600;color:#1e293b;text-transform:capitalize;">{{this.category}}</span>
          <span style="font-size:12px;color:#64748b;">
            {{this.risolti}}/{{this.totale}} risolti
            <strong style="margin-left:6px;color:{{this.colore}};">{{this.tassoPerc}}%</strong>
          </span>
        </div>
        <div style="background:#e2e8f0;border-radius:4px;height:10px;overflow:hidden;">
          <div style="height:100%;border-radius:4px;background:{{this.colore}};width:{{this.tassoPerc}}%;transition:width .4s ease;"></div>
        </div>
      </div>
      {{/each}}
      {{#unless tassoCategoria}}
      <p style="color:#94a3b8;font-size:13px;">Nessun dato disponibile.</p>
      {{/unless}}
      <div style="display:flex;gap:16px;margin-top:14px;padding-top:12px;border-top:1px solid #f1f5f9;">
        <span style="font-size:11px;color:#64748b;display:flex;align-items:center;gap:4px;">
          <span style="width:10px;height:10px;border-radius:2px;background:#22c55e;display:inline-block;"></span>≥ 75% ottimo
        </span>
        <span style="font-size:11px;color:#64748b;display:flex;align-items:center;gap:4px;">
          <span style="width:10px;height:10px;border-radius:2px;background:#f59e0b;display:inline-block;"></span>40–74% nella norma
        </span>
        <span style="font-size:11px;color:#64748b;display:flex;align-items:center;gap:4px;">
          <span style="width:10px;height:10px;border-radius:2px;background:#ef4444;display:inline-block;"></span>&lt; 40% critico
        </span>
      </div>
    </div>

  </div>

  <div class="col-sidebar">
    <div class="sidebar-sticky">

      {{!-- Distribuzione per categoria --}}
      <div class="card" style="margin-bottom:1rem;">
        <h3>Per categoria</h3>
        <div style="margin-top:0.75rem;">
          {{#each byCategory}}
          <div class="bar-row">
            <span class="bar-label">{{capitalize this.category}}</span>
            <div class="bar-container">
              <div class="bar bar-blue" style="width: {{this.percentage}}%">{{this.count}}</div>
            </div>
          </div>
          {{/each}}
        </div>
      </div>

      {{!-- Distribuzione per stato --}}
      <div class="card" style="margin-bottom:1rem;">
        <h3>Per stato</h3>
        <div style="margin-top:0.75rem;">
          {{#each byStatus}}
          <div class="bar-row">
            <span class="bar-label">{{capitalize this.status}}</span>
            <div class="bar-container">
              <div class="bar bar-blue" style="width: {{this.percentage}}%">{{this.count}}</div>
            </div>
          </div>
          {{/each}}
        </div>
      </div>

      {{!-- Distribuzione per priorità --}}
      <div class="card">
        <h3>Per priorità</h3>
        <div style="margin-top:0.75rem;">
          {{#each byPriority}}
          <div class="bar-row">
            <span class="bar-label">{{capitalize this.priority}}</span>
            <div class="bar-container">
              <div class="bar bar-blue" style="width: {{this.percentage}}%">{{this.count}}</div>
            </div>
          </div>
          {{/each}}
        </div>
      </div>

    </div>
  </div>
</div>
