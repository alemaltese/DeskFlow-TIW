<div style="max-width:560px; margin:0 auto;">
  <div style="margin-bottom:1rem;">
    <a href="/admin/utenti" class="btn btn-secondary btn-sm">← Utenti</a>
  </div>

  <div class="card">
    <h2>{{title}}</h2>

    {{#if errors}}
    <div class="flash flash-error" style="margin-bottom:1rem;">
      <ul style="margin:0; padding-left:1.2rem;">
        {{#each errors}}<li>{{this}}</li>{{/each}}
      </ul>
    </div>
    {{/if}}

    <form action="{{#if isNew}}/admin/utenti{{else}}/admin/utenti/{{user.id}}{{/if}}" method="POST">
      <div class="form-group">
        <label for="name">Nome completo</label>
        <input type="text" id="name" name="name" value="{{user.name}}" required maxlength="100">
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" value="{{user.email}}" required maxlength="255">
      </div>
      <div class="form-group">
        <label for="role">Ruolo</label>
        <select id="role" name="role">
          <option value="utente"    {{#if (eq user.role "utente")}}selected{{/if}}>Utente</option>
          <option value="operatore" {{#if (eq user.role "operatore")}}selected{{/if}}>Operatore</option>
        </select>
      </div>

      <hr style="border:none; border-top:1px solid #e2e8f0; margin:1.5rem 0;">

      {{#if isNew}}
      <div class="form-group">
        <label for="password">Password <span style="color:#e53e3e;">*</span></label>
        <div class="pw-wrap">
          <input type="password" id="password" name="password" minlength="6" required autocomplete="new-password">
          <button type="button" class="pw-toggle" onclick="togglePw(this)" tabindex="-1" aria-label="Mostra password">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
      </div>
      {{else}}
      <h3 style="font-size:1rem; margin-bottom:0.75rem;">Cambia password</h3>
      <p class="text-muted" style="font-size:0.85rem; margin-bottom:1rem;">Lascia vuoto per mantenere la password attuale.</p>
      <div class="form-group">
        <label for="new_password">Nuova password</label>
        <div class="pw-wrap">
          <input type="password" id="new_password" name="new_password" minlength="6" autocomplete="new-password">
          <button type="button" class="pw-toggle" onclick="togglePw(this)" tabindex="-1" aria-label="Mostra password">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
      </div>
      {{/if}}

      <div style="margin-top:1rem;">
        <button type="submit" class="btn btn-primary">{{#if isNew}}Crea utente{{else}}Salva modifiche{{/if}}</button>
        <a href="/admin/utenti" class="btn btn-secondary" style="margin-left:0.5rem;">Annulla</a>
      </div>
    </form>
  </div>
</div>
