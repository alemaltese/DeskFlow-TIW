<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
  <h1>Tutti i ticket</h1>
</div>

<form class="filters-bar" method="GET" action="/admin/tickets">
  <div class="filters-row">
    <select name="status" class="filter-select">
      <option value="">Tutti gli stati</option>
      <option value="aperto" {{#ifEq activeFilters.status "aperto"}}selected{{/ifEq}}>Aperto</option>
      <option value="in_corso" {{#ifEq activeFilters.status "in_corso"}}selected{{/ifEq}}>In corso</option>
      <option value="risolto" {{#ifEq activeFilters.status "risolto"}}selected{{/ifEq}}>Risolto</option>
      <option value="chiuso" {{#ifEq activeFilters.status "chiuso"}}selected{{/ifEq}}>Chiuso</option>
    </select>
    <select name="priority" class="filter-select">
      <option value="">Tutte le priorità</option>
      <option value="bassa">Bassa</option>
      <option value="media">Media</option>
      <option value="alta">Alta</option>
      <option value="urgente">Urgente</option>
    </select>
    <select name="category" class="filter-select">
      <option value="">Tutte le categorie</option>
      <option value="tecnico">Tecnico</option>
      <option value="account">Account</option>
      <option value="fatturazione">Fatturazione</option>
      <option value="altro">Altro</option>
    </select>
    <select name="assigned_to" class="filter-select">
      <option value="">Tutti gli operatori</option>
      <option value="null">Non assegnati</option>
      {{#each operators}}
      <option value="{{this.id}}">{{this.name}}</option>
      {{/each}}
    </select>
    <input type="text" name="search" class="filter-input" placeholder="Cerca nel titolo..." value="{{activeFilters.search}}">
    <button type="submit" class="btn btn-primary btn-sm">Filtra</button>
    <a href="/admin/tickets" class="btn btn-secondary btn-sm">Reset</a>
  </div>
</form>

{{#if tickets.length}}
<div class="card" style="margin-top:1rem;">
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Titolo</th>
        <th>Utente</th>
        <th>Operatore</th>
        <th>Categoria</th>
        <th>Priorità</th>
        <th>Stato</th>
        <th>Data</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{#each tickets}}
      <tr>
        <td>{{this.id}}</td>
        <td>{{this.title}}</td>
        <td>{{this.user_name}}</td>
        <td>{{#if this.operator_name}}{{this.operator_name}}{{else}}<span class="text-muted">—</span>{{/if}}</td>
        <td>{{capitalize this.category}}</td>
        <td><span class="badge badge-{{this.priority}}">{{capitalize this.priority}}</span></td>
        <td><span class="badge badge-{{this.status}}">{{capitalize this.status}}</span></td>
        <td>{{formatDate this.created_at}}</td>
        <td><a href="/admin/tickets/{{this.id}}" class="btn btn-sm btn-primary">Gestisci</a></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>
{{else}}
<div class="card" style="margin-top:1rem;">
  <p class="text-muted">Nessun ticket trovato.</p>
</div>
{{/if}}
