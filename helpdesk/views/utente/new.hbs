<div class="card" style="max-width: 680px; margin: 0 auto;">
  <div class="card-header">
    <h1>Apri nuovo ticket</h1>
    <a href="/tickets" class="btn btn-secondary btn-sm">Annulla</a>
  </div>

  {{#if errors}}
  <div class="flash flash-error">
    <ul style="margin:0; padding-left:1.25rem;">
      {{#each errors}}<li>{{this}}</li>{{/each}}
    </ul>
  </div>
  {{/if}}

  <form action="/tickets" method="POST">
    <div class="form-group">
      <label for="title">Titolo <span style="color:#dc2626">*</span></label>
      <input
        type="text"
        id="title"
        name="title"
        value="{{old.title}}"
        maxlength="100"
        placeholder="Descrivi brevemente il problema..."
        required
      >
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
      <div class="form-group">
        <label for="category">Categoria <span style="color:#dc2626">*</span></label>
        <select id="category" name="category" required>
          <option value="">— Seleziona —</option>
          {{#each categories}}
          <option value="{{this}}" {{#if (eq ../old.category this)}}selected{{/if}}>
            {{capitalize this}}
          </option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label for="priority">Priorità <span style="color:#dc2626">*</span></label>
        <select id="priority" name="priority" required>
          <option value="">— Seleziona —</option>
          {{#each priorities}}
          <option value="{{this}}" {{#if (eq ../old.priority this)}}selected{{/if}}>
            {{capitalize this}}
          </option>
          {{/each}}
        </select>
      </div>
    </div>

    <div class="form-group">
      <label for="description">Descrizione <span style="color:#dc2626">*</span></label>
      <textarea
        id="description"
        name="description"
        rows="6"
        maxlength="2000"
        placeholder="Descrivi il problema in dettaglio: cosa hai fatto, cosa ti aspettavi, cosa è successo invece..."
        required
      >{{old.description}}</textarea>
    </div>

    <div style="display:flex; gap:1rem; align-items:center; margin-top:0.5rem;">
      <button type="submit" class="btn btn-primary">Apri Ticket</button>
      <a href="/tickets" class="btn btn-secondary">Annulla</a>
    </div>
  </form>
</div>
