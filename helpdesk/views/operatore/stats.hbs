<h1>Le mie statistiche</h1>
<p class="text-muted" style="margin-bottom:1.5rem; font-size:0.875rem;">Ultimi 30 giorni</p>

{{!-- KPI personali --}}
<div class="kpi-grid" style="margin-bottom:2rem; grid-template-columns: repeat(3, 1fr);">
  <div class="kpi-card">
    <div class="kpi-number">{{kpi.totalAssigned}}</div>
    <div class="kpi-label">Ticket assegnati</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-number">{{kpi.totalRisolti}}</div>
    <div class="kpi-label">Ticket risolti</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-number">
      {{#if kpi.avgRating}}
        {{kpi.avgRating}}
        <span style="font-size:1rem; color:#f59e0b;">
          {{#each kpi.avgRatingStars}}{{#if this}}★{{else}}☆{{/if}}{{/each}}
        </span>
      {{else}}—{{/if}}
    </div>
    <div class="kpi-label">Rating medio ricevuto</div>
  </div>
</div>

<div class="two-col-layout">
  <div class="col-main">

    {{!-- Trend 7 giorni --}}
    <div class="card">
      <h2>Trend ultimi 7 giorni</h2>
      <div class="chart-vertical" style="margin-top:1.25rem;">
        {{#each trend}}
        <div class="chart-col">
          <div class="chart-bar" style="height: {{this.heightPerc}}%">
            <span class="chart-value">{{this.count}}</span>
          </div>
          <span class="chart-label">{{this.date}}</span>
        </div>
        {{/each}}
      </div>
    </div>

  </div>

  <div class="col-sidebar">
    <div class="sidebar-sticky">

      {{!-- Distribuzione per stato --}}
      <div class="card" style="margin-bottom:1rem;">
        <h3>I miei ticket per stato</h3>
        {{#if byStatus.length}}
        <div style="margin-top:0.75rem;">
          {{#each byStatus}}
          <div class="bar-row">
            <span class="bar-label">{{capitalize this.status}}</span>
            <div class="bar-container">
              <div class="bar bar-blue" style="width: {{this.percentage}}%">{{this.count}}</div>
            </div>
          </div>
          {{/each}}
        </div>
        {{else}}
        <p class="text-muted" style="margin-top:0.5rem;">Nessun dato.</p>
        {{/if}}
      </div>

      {{!-- Distribuzione per priorità --}}
      <div class="card">
        <h3>I miei ticket per priorità</h3>
        {{#if byPriority.length}}
        <div style="margin-top:0.75rem;">
          {{#each byPriority}}
          <div class="bar-row">
            <span class="bar-label">{{capitalize this.priority}}</span>
            <div class="bar-container">
              <div class="bar bar-blue" style="width: {{this.percentage}}%">{{this.count}}</div>
            </div>
          </div>
          {{/each}}
        </div>
        {{else}}
        <p class="text-muted" style="margin-top:0.5rem;">Nessun dato.</p>
        {{/if}}
      </div>

    </div>
  </div>
</div>
